generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TripMemberRole {
  OWNER
  EDITOR
  VIEWER
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  image        String?
  passwordHash String
  createdTrips Trip[]   @relation("TripCreator")
  memberships  TripMember[]
  votes        Vote[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Trip {
  id                 String   @id @default(cuid())
  name               String
  destination        String
  destinationLat     Float?
  destinationLng     Float?
  startDate          DateTime
  endDate            DateTime
  headcount          Int      @default(1)
  totalBudgetCents   Int?
  housingPrefsJson   String?
  planningStep       String   @default("setup")
  createdById        String
  createdBy          User     @relation("TripCreator", fields: [createdById], references: [id], onDelete: Restrict)
  members            TripMember[]
  invites            Invite[]
  itineraryVersions  ItineraryVersion[]
  activityCandidates ActivityCandidate[]
  housingCandidates  HousingCandidate[]
  transportCandidates TransportCandidate[]
  validationRuns     ValidationRun[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model TripMember {
  id     String         @id @default(cuid())
  tripId String
  userId String
  role   TripMemberRole @default(VIEWER)
  trip   Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tripId, userId])
  @@index([userId])
}

model Invite {
  id        String         @id @default(cuid())
  tripId    String
  token     String         @unique
  email     String?
  role      TripMemberRole @default(EDITOR)
  expiresAt DateTime?
  trip      Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())
}

model ItineraryVersion {
  id        String   @id @default(cuid())
  tripId    String
  label     String?
  snapshot  Json
  isActive  Boolean  @default(false)
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([tripId, isActive])
}

model ActivityCandidate {
  id           String   @id @default(cuid())
  tripId       String
  placeId      String
  category     String
  name         String?
  dayIndex     Int?
  metadataJson Json?
  trip         Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  votes        Vote[]

  @@index([tripId])
  @@index([tripId, dayIndex])
}

model HousingCandidate {
  id              String  @id @default(cuid())
  tripId          String
  provider        String
  providerHotelId String?
  name            String?
  nightlyCents    Int?
  deepLinkUrl     String?
  metadataJson    Json?
  trip            Trip    @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
}

model TransportCandidate {
  id           String  @id @default(cuid())
  tripId       String
  mode         String
  segmentsJson Json?
  priceCents   Int?
  metadataJson Json?
  trip         Trip    @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
}

model Vote {
  id                  String            @id @default(cuid())
  userId              String
  tripId              String
  dayIndex            Int
  activityCandidateId String
  score               Int
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  activityCandidate   ActivityCandidate @relation(fields: [activityCandidateId], references: [id], onDelete: Cascade)

  @@unique([userId, tripId, dayIndex, activityCandidateId])
  @@index([tripId, dayIndex])
}

model ValidationRun {
  id        String   @id @default(cuid())
  tripId    String
  flagsJson Json
  aiNotes   String?
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([tripId])
}

model PlaceDetailCache {
  placeId   String   @id
  payload   Json
  fetchedAt DateTime @default(now())
}

model PlacesSearchCache {
  cacheKey  String   @id
  payload   Json
  fetchedAt DateTime @default(now())
}

model RoutesMatrixCache {
  cacheKey  String   @id
  payload   Json
  fetchedAt DateTime @default(now())
}
