# Database (Neon, Supabase, or local Postgres)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Auth.js — generate: openssl rand -base64 32
AUTH_SECRET=""

# App URL (production: https://your-domain.com)
AUTH_TRUST_HOST="true"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Google Maps Platform (server key — restrict by IP in GCP)
GOOGLE_MAPS_API_KEY=""

# Amadeus Self-Service (https://developers.amadeus.com/)
AMADEUS_API_KEY=""
AMADEUS_API_SECRET=""
AMADEUS_HOST="https://test.api.amadeus.com"

# OpenAI for structured planning (optional until wired)
OPENAI_API_KEY=""
